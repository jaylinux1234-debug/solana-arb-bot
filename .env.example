# Copy to `.env` (never commit). API keys go in secrets/.local/ → SOPS encrypt → secrets/encrypted/
# One-time: npm run secrets:migrate   |   Daily: npm run secrets:encrypt-local
# compose.env is auto-generated (non-secrets only): npm run sync:compose-env
# See secrets/README.md

# === ONLY NON-SECRETS ===
APP_ENV=production
# Set true for $5–50 trade caps (MAX_FLASH_USDC<1000); omit for institutional (>=10k USDC cap)
GO_LIVE_SMALL_ACCOUNT=
TEST_MODE=false
LIVE_TRADING_CONFIRM=
SIGNER_TYPE=hot
ALLOW_HOT_KEY_IN_PROD=0
# Strict mode: reject legacy .env.txt; abort if WALLET_PUBKEY mismatches signer
DENY_DOT_ENV_TXT=true
ENFORCE_WALLET_PUBKEY=true
SECRET_MANAGER=local
SECRETS_ENCRYPTION=sops

# RPC
RPC_PROVIDER=multi
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SOLANA_RPC_URL_FALLBACK=https://api.mainnet-beta.solana.com
QUICKNODE_RPC=
ALCHEMY_KEY=

# Trading
AI_APPROVE_MIN_CONFIDENCE=82
CEX_DEX_MIN_NET_SPREAD_BPS=35
CEX_DEX_MAX_TRADE_USDC_MICRO=15000000
# Jupiter probe notional (micro USDC); match typical trade size for direction/depth alignment.
CEX_DEX_PROBE_USDC_MICRO=12000000
# CEX buy reference = best ask (Plan 4 direction alignment).
CEX_USE_ASK_FOR_BUY=true
CEX_DEX_ORACLE_POLL_MIN_SEC=1
CEX_DEX_BRAIN_PRIORITY_BIAS=80
STRATEGY_PRIORITY_ORDER=cex_dex,backrun,collateral_swap,liquidation
CEX_DEX_VOL_GATE_ENABLED=true
ENABLE_ONCHAIN_PROFIT_ASSERT=true
ONCHAIN_PROFIT_ASSERT_BPS=12
ONCHAIN_PROFIT_ASSERT_STRICT=true
JITO_TIP_LAMPORTS=100000
LIVE_TRADE_COOLDOWN_SECONDS=120
MIN_NET_PROFIT_BPS=35

# Wallet (public only)
WALLET_PUBKEY=

# Logging (Loki host port — use 3101 if 3100 is taken by another stack e.g. flash-loki)
LOKI_PORT=3101
LOKI_HOST=0.0.0.0

# === MEV / v2 hybrid (Tier 1–3) ===
V2_ROUTER_MEV_ONLY=false
ENABLE_HELIUS_WEBHOOK=true
HELIUS_WEBHOOK_PORT=8799
HELIUS_WEBHOOK_PUBLIC_URL=
HELIUS_WEBHOOK_PATH=/helius/webhook
HELIUS_WEBHOOK_AUTO_CREATE=false
ENABLE_HELIUS_WEBHOOK_BACKRUN=true
HELIUS_JUPITER_SOURCES=JUPITER,PHOENIX
HELIUS_BACKRUN_MIN_AMOUNT_MICRO=35000000
BACKRUN_SIGNAL_TTL_SEC=30
BACKRUN_MIN_NET_BPS=25
BACKRUN_MIN_PROFIT_USD=3.0
BACKRUN_SIZE_FRACTION=0.5
BACKRUN_SLIPPAGE_BPS=80
BACKRUN_EXTRA_JUPITER_LEG_BPS=24
BACKRUN_DEDUP_TTL_SEC=45
ENABLE_MEV_LOGGING=true
JITO_TIP_MIN_LAMPORTS=45000
JITO_TIP_MAX_LAMPORTS=350000
JITO_TIP_PROFIT_RATIO=0.55
ENABLE_COLLATERAL_RATE_ARB=true
COLLATERAL_MIN_NET_BPS=35
COLLATERAL_FLASH_AMOUNT_USDC_MICRO=35000000
COLLATERAL_JITO_TIP_BPS=8
COLLATERAL_MAX_PLAUSIBLE_CARRY_BPS=500

# Liquidations (Kamino)
ENABLE_LIQUIDATION_MONITORING=true
LIQUIDATION_MIN_PROFIT_USDC=4.0
LIQUIDATION_MAX_FLASH_USDC=35
KAMINO_ALERT_MIN_UTIL=0.92
KAMINO_ALERT_MIN_LTV_RATIO=0.92
LIQUIDATION_BONUS_PCT=0.05
LIQUIDATION_NET_RETAIN_FRAC=0.65
LIQUIDATION_AI_MIN_CONFIDENCE=58
