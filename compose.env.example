# Copy to compose.env for Docker (never commit compose.env with real URLs).
# Loaded after .env in docker-compose.yml / docker-compose.prod.yml.

# quicknode | alchemy | multi (weighted WS failover across all configured endpoints)
RPC_PROVIDER=multi

QUICKNODE_RPC=https://your-quicknode.base-mainnet.endpoint
QUICKNODE_WS=wss://your-quicknode.base-mainnet.endpoint

ALCHEMY_RPC=https://base-mainnet.g.alchemy.com/v2/your_alchemy_key
ALCHEMY_WS=wss://base-mainnet.g.alchemy.com/v2/your_alchemy_key
ALCHEMY_KEY=your_alchemy_key

BASE_RPC=https://mainnet.base.org
BASE_WS=wss://mainnet.base.org
FALLBACK_WS=wss://mainnet.base.org

RPC_RATE_PER_SEC=8
RPC_RATE_CAPACITY=16
WS_CONNECT_MAX_ATTEMPTS=20
WS_CONNECT_BASE_BACKOFF_SEC=8
WS_PING_INTERVAL=25
WS_PING_TIMEOUT=50

MONITOR_POLL_SEC=12
