{
  "name": "solana-arb-bot",
  "version": "0.3.0",
  "description": "Solana CEX-DEX Arbitrage Bot with SOPS hot-wallet signing, AI decisions, and production monitoring",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "ledger:install": "node -e \"console.log('Ledger removed — hot wallet only (SIGNER_TYPE=hot + SOPS private_key)')\"",
    "setup:install": "node scripts/setup-install.mjs",
    "setup:install:sh": "bash scripts/setup-install.sh",
    "setup:install:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-install.ps1",
    "deps:lock": "node scripts/compile-requirements.mjs",
    "deps:sync": "node scripts/deps-sync.mjs",
    "deps:sync:dev": "node scripts/deps-sync.mjs --dev",
    "fetch:klend-idl": "node scripts/fetch-klend-idl.mjs",
    "sync:compose-env": "node scripts/sync-compose-env.mjs",
    "backtest:cex-dex": "python src/scripts/cex_dex_sim_batch.py --count 50 --mode jupiter_swap --gross-bps 15 --size 20000000",
    "backtest:cex-dex:scenarios": "node scripts/run-cex-dex-scenarios.mjs",
    "backtest:tune": "python scripts/backtest_tune_cex_dex.py --scenarios-only --gross-min 8 --gross-max 22 --size 20000000",
    "backtest:tune:all-pairs": "python scripts/backtest_tune_cex_dex.py --all-pairs --scenarios-only --gross-min 8 --gross-max 22 --size 12000000",
    "scan:pairs": "python -m src.scripts.multi_pair_scanner",
    "scan:pairs:weekly": "node scripts/run-weekly-pair-scan.mjs",
    "backtest:tune:sim": "python scripts/backtest_tune_cex_dex.py --gross-min 10 --gross-max 20 --size 20000000 --sim-count 10",
    "backtest:frequent": "node scripts/backtest_run_frequent.mjs",
    "train:ml": "node scripts/run-train-ml.mjs",
    "train:ml:ensemble": "node scripts/run-train-ml.mjs -- --ensemble --min-samples 30",
    "train:ml:real-fills": "python -m src.ml.train_real_fills",
    "analyze:live": "python scripts/analyze_live_logs_extended.py",
    "pnl:analyze": "python scripts/analyze_pnl.py",
    "pnl:backfill": "python scripts/backfill_v2_pnl.py",
    "results:fill-rate": "python scripts/show_fill_rate_results.py",
    "dashboard:daily": "python scripts/daily_funnel.py",
    "probe:daily": "python scripts/daily_gate_probe.py",
    "probe:volatility": "python scripts/volatility_gate.py",
    "monitor:enhanced": "python -u scripts/enhanced_monitor.py",
    "metrics:next": "python scripts/next_level_metrics.py",
    "v2:start": "python -m src.v2.main",
    "v2:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-v2.ps1",
    "v2:health": "curl.exe -sf http://127.0.0.1:8000/health",
    "v2:health:detailed": "curl.exe -sf http://127.0.0.1:8000/health/detailed",
    "v2:test": "python -m pytest tests/test_v2_gates.py -q",
    "v2:test-cex": "python scripts/test_v2_cex_quote.py",
    "v2:usdc-sync": "python scripts/usdc_inventory_sync.py --force",
    "v2:balance": "python scripts/v2_wallet_balance.py",
    "track:capital": "python scripts/track_capital_delta.py",
    "rearm:phase1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/rearm-phase1.ps1",
    "v2:fund-usdc": "python scripts/v2_withdraw_usdc.py",
    "tier:f:baseline": "python scripts/next_level_metrics.py && npm run probe:daily && npm run sim:breakeven:live",
    "tier:f:baseline:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tier_f_baseline.ps1",
    "sim:breakeven": "python scripts/breakeven_sim.py",
    "sim:breakeven:live": "python scripts/breakeven_sim.py --live-quotes",
    "inventory:usdc-sync": "python scripts/usdc_inventory_sync.py",
    "inventory:usdc-sync:dry": "python scripts/usdc_inventory_sync.py --dry-run",
    "inventory:usdc-sync:force": "python scripts/usdc_inventory_sync.py --force",
    "inventory:usdc-sync:dry:force": "python scripts/usdc_inventory_sync.py --dry-run --force",
    "tune:auto": "python scripts/auto_tuner.py",
    "tune:auto:apply": "python scripts/auto_tuner.py --apply",
    "tune:auto:fill-mode": "python scripts/auto_tuner.py --fill-mode",
    "tune:auto:fill-mode:apply": "python scripts/auto_tuner.py --fill-mode --apply",
    "tune:auto:watch": "python scripts/auto_tuner.py --watch 900",
    "tune:auto:watch:fast": "python scripts/auto_tuner.py --watch 300",
    "mev:watch": "python scripts/mev_watch.py --tail 500",
    "mev:watch:live": "powershell -NoProfile -Command \"$t = if ($env:MEV_WATCH_TAIL) { [int]$env:MEV_WATCH_TAIL } elseif ($env:npm_config_tail) { [int]$env:npm_config_tail } else { 20 }; Get-Content logs/v2_attempts.jsonl -Wait -Tail $t | Select-String -Pattern 'backrun|collateral|liquidation|MEV|kamino'\"",
    "mev:dashboard": "npm run dashboard:daily && npm run metrics:next && npm run pnl:analyze",
    "train:ml:regime": "python -m src.ml.regime_detector",
    "deploy:blue-green": "node scripts/blue-green-deploy.mjs",
    "singleton:guard": "python scripts/singleton_guard.py status",
    "singleton:reclaim": "python scripts/singleton_guard.py reclaim",
    "deploy:next-level": "bash scripts/next_level_deploy.sh",
    "deploy:next-level:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/next_level_deploy.ps1",
    "pause:hours": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pause-for-hours.ps1",
    "gates:auto": "python scripts/auto_gate_switcher.py",
    "gates:auto:once": "python scripts/auto_gate_switcher.py --once",
    "phase4:ml": "npm run analyze:live && npm run train:ml:ensemble",
    "env:migrate": "node scripts/migrate-env-txt.mjs",
    "secrets:migrate": "node scripts/migrate-env-to-sops.mjs",
    "secrets:migrate:dry": "node scripts/migrate-env-to-sops.mjs --dry-run",
    "secrets:encrypt-local": "node scripts/sops-encrypt-local.mjs",
    "secrets:init": "node scripts/init-secrets-templates.mjs",
    "secrets:sync-local": "node scripts/sync-secrets-local.mjs --migrate-env",
    "secrets:prune-encrypted": "node scripts/prune-encrypted-secrets.mjs",
    "secrets:encrypt": "node scripts/prune-encrypted-secrets.mjs && node scripts/ensure-encrypted-secrets.mjs --encrypt",
    "secrets:check": "node scripts/prune-encrypted-secrets.mjs && node scripts/ensure-encrypted-secrets.mjs",
    "secrets:validate": "python scripts/validate-secrets.py",
    "go-live:secrets:sh": "node scripts/go-live-secrets.mjs",
    "go-live:preflight:sh": "node scripts/go-live-preflight.mjs",
    "go-live:simulate": "node scripts/go-live-simulate.mjs",
    "go-live:monitoring": "node scripts/go-live-monitoring.mjs",
    "compose:simulate:down": "node scripts/compose-simulate-down.mjs",
    "compose:prod:up": "node scripts/compose-prod-up.mjs",
    "compose:prod:down": "docker compose --env-file compose.env -f docker-compose.yml -f infra/compose/docker-compose.prod.yml -f infra/compose/docker-compose.prod.override.yml -f infra/compose/docker-compose.monitoring.yml down",
    "compose:prod:restart": "node scripts/compose-prod-restart.mjs",
    "compose:prod:restart:no-build": "node scripts/compose-prod-restart.mjs --no-build",
    "compose:health": "node scripts/compose-health-gate.mjs",
    "restart:monitor": "node scripts/restart-monitor.mjs",
    "restart:monitor:sh": "bash scripts/restart-monitor.sh",
    "logs:tail": "node scripts/logs-tail.mjs",
    "logs:errors": "node scripts/logs-errors.mjs",
    "ops:auto-relax:min-sim-net": "bash ops/auto-relax-min-sim-net.sh",
    "health:quick": "node scripts/health-quick.mjs",
    "sim:local": "node scripts/sim-local.mjs",
    "verify:live": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-live.ps1",
    "verify:live:sh": "bash scripts/verify-live.sh",
    "compile": "hardhat compile",
    "deploy:secure": "node scripts/deploy-secure.mjs base-mainnet",
    "verify:base": "node scripts/verify-base.mjs",
    "verify:base:force": "node scripts/verify-base.mjs --force",
    "audit:all": "bash scripts/audit-all.sh",
    "audit:all:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/audit-all.ps1",
    "test:py": "python -m pytest tests/ -q -p no:anchorpy",
    "backup:state": "python scripts/backup-daily-state.py",
    "dev": "nodemon --exec \"node --loader ts-node/esm\" hardhat.config.ts",
    "build": "tsc"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "hardhat": "^3.7.0",
    "nodemon": "^3.1.14",
    "solhint": "^5.0.5",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "solana",
    "arbitrage",
    "cex-dex",
    "jupiter",
    "backpack"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bs58": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2"
  }
}
