# Profile: safe accumulation (SOL-only, quality-first)
# Apply: bash scripts/switch_profile.sh accumulation

APP_ENV=production
TEST_MODE=false
SIMULATE=false
LIVE_TRADING_CONFIRM=YES
SIGNER_TYPE=hot

CEX_MIDCAPS=SOL
CEX_MAX_MIDCAPS=1
CEX_DEX_INCLUDE_SOL=true

CEX_DEX_MIN_GROSS_SPREAD_BPS=8
CEX_DEX_MIN_NET_SPREAD_BPS=3
CEX_DEX_MAX_TRADE_USDC_MICRO=15000000
CEX_DEX_MIN_TRADE_USDC_MICRO=8000000
CEX_DEX_ROUNDTRIP_SIM_MIN_NET_BPS=0

ENABLE_PHOENIX_V1=true
PHOENIX_PROBE_USDC_MICRO=12000000

JITO_TIP_LAMPORTS=150000
JITO_DYNAMIC_TIP=true
JITO_TIP_LAMPORTS_MAX=300000

STRATEGY_PRIORITY_ORDER=cex_dex,backrun,collateral_swap,liquidation
CEX_DEX_BRAIN_PRIORITY_BIAS=65
BRAIN_CEX_DEX_WEAK_REDIRECT=false

ML_REAL_FILLS_APPROVE_GATE=true
ML_REAL_FILLS_APPROVE_MIN_PROBA=0.68
