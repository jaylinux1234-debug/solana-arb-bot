# VPS aggressive preset (higher fill rate, higher variance)
# Apply by copying selected values into .env/compose.env

# Faster scan cadence and broader execution probing
CEX_DEX_ORACLE_POLL_MIN_SEC=1.0
CEX_DEX_ORACLE_POLL_MAX_SEC=2.5
CEX_DEX_EXEC_SCAN_TOP_N=3
CEX_DEX_EXEC_SIZE_LADDER=1.0,0.8,0.6,0.45,0.3
CEX_DEX_DYNAMIC_MIN_TRADE_PER_BPS_MICRO=450000
CEX_DEX_DYNAMIC_MIN_TRADE_CAP_MICRO=7000000
CEX_DEX_MODEL_NET_SOFT_RESCUE=true
CEX_DEX_MODEL_NET_SOFT_RESCUE_MIN_GROSS_BPS=8
CEX_DEX_MODEL_NET_SOFT_RESCUE_SYMBOLS=SOL,WIF
CEX_DEX_MODEL_NET_SOFT_RESCUE_BYPASS_NET_GATE=true

# More permissive gates
CEX_DEX_MIN_GROSS_SPREAD_BPS=6
CEX_DEX_MIN_NET_SPREAD_BPS=1.2
CEX_DEX_AI_CONFIDENCE_FLOOR=52
CEX_VOL_STRICT_GROSS_BPS=8
CEX_VOL_STRICT_NET_BPS=2
CEX_VOL_STRICT_AI_CONF=62

# Tighter cost assumptions (monitor realized slippage closely)
CEX_DEX_EXECUTION_SLIPPAGE_BUFFER_BPS=24
CEX_DEX_SIZE_IMPACT_SLOPE_BPS=3.5
CEX_DEX_SIZE_IMPACT_EXPONENT=1.08
CEX_DEX_SIZE_IMPACT_REF_USDC=32

# Sizing and throughput
MAX_FLASH_USDC=14
CEX_DEX_MAX_TRADE_USDC_MICRO=14000000
CEX_DEX_MIN_TRADE_USDC_MICRO=4500000
CEX_DEX_PROBE_USDC_MICRO=7000000
LIVE_TRADE_COOLDOWN_SECONDS=60
MAX_LIVE_TRADES_PER_HOUR=12

# Set this to 0.0.0.0 only when webhook ingress is required
WEBHOOK_BIND_IP=127.0.0.1
