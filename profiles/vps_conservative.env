# VPS conservative preset (safer, lower variance)
# Apply by copying selected values into .env/compose.env

# Scan + execution cadence
CEX_DEX_ORACLE_POLL_MIN_SEC=1.5
CEX_DEX_ORACLE_POLL_MAX_SEC=3.5
CEX_DEX_EXEC_SCAN_TOP_N=2
CEX_DEX_EXEC_SIZE_LADDER=1.0,0.85,0.7,0.55
CEX_DEX_DYNAMIC_MIN_TRADE_PER_BPS_MICRO=600000
CEX_DEX_DYNAMIC_MIN_TRADE_CAP_MICRO=9000000
CEX_DEX_MODEL_NET_SOFT_RESCUE=true
CEX_DEX_MODEL_NET_SOFT_RESCUE_MIN_GROSS_BPS=9
CEX_DEX_MODEL_NET_SOFT_RESCUE_SYMBOLS=SOL,WIF
CEX_DEX_MODEL_NET_SOFT_RESCUE_BYPASS_NET_GATE=true

# Core gates (keep quality high)
CEX_DEX_MIN_GROSS_SPREAD_BPS=7
CEX_DEX_MIN_NET_SPREAD_BPS=2.0
CEX_DEX_AI_CONFIDENCE_FLOOR=58
CEX_VOL_STRICT_GROSS_BPS=9
CEX_VOL_STRICT_NET_BPS=3
CEX_VOL_STRICT_AI_CONF=68

# Cost model guardrails
CEX_DEX_EXECUTION_SLIPPAGE_BUFFER_BPS=28
CEX_DEX_SIZE_IMPACT_SLOPE_BPS=4
CEX_DEX_SIZE_IMPACT_EXPONENT=1.12
CEX_DEX_SIZE_IMPACT_REF_USDC=30

# Sizing and safety
MAX_FLASH_USDC=12
CEX_DEX_MAX_TRADE_USDC_MICRO=12000000
CEX_DEX_MIN_TRADE_USDC_MICRO=6000000
CEX_DEX_PROBE_USDC_MICRO=8000000
LIVE_TRADE_COOLDOWN_SECONDS=90
MAX_LIVE_TRADES_PER_HOUR=8

# Keep webhook public only if needed
WEBHOOK_BIND_IP=127.0.0.1
