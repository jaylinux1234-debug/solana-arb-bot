# Copy to `.env` (never commit). Secrets: secrets/.local/ + secrets/encrypted/ (SOPS) — see secrets/README.md

SOLANA_RPC_URL=https://your-helius-dev-endpoint.example.com
# Faster RPC for Jupiter quotes / sims (Helius dev tier recommended).
SOLANA_RPC_URL_FAST=https://your-helius-fast-endpoint.example.com
# Public mainnet-beta only when explicitly allowed (not for production sends).
ALLOW_PUBLIC_RPC_FALLBACK=false
SOLANA_RPC_COMMITMENT=confirmed
SOLANA_RPC_TIMEOUT_SEC=45
SOLANA_RPC_WS_URL=
YELLOWSTONE_GRPC_URL=
SILENCE_RPC_TIER_WARNINGS=false

# Daily CEX SOL snapshot + optional cross-check vs on-chain wallet (see inventory_reconcile.py).
ENABLE_DAILY_INVENTORY_RECONCILE=true
INVENTORY_RECONCILE_INTERVAL_SEC=86400
INVENTORY_RECONCILE_ALERT_DELTA_SOL=0.25
INVENTORY_RECONCILE_CROSS_ALERT_DELTA_SOL=0

# Jito: await getBundleStatuses in-process after send (in addition to background poll).
JITO_AWAIT_BUNDLE_POLL=false

# AI min confidence: extra floor when rolling PnL (USD) in window is negative (see pnl_confidence.py).
AI_CONFIDENCE_PNL_DYNAMICS=true
AI_PNL_CONFIDENCE_WINDOW_HOURS=72
PNL_CONFIDENCE_STATE_PATH=logs/pnl_confidence_window.json

PRIVATE_KEY=
# Optional: separate signer for CEX-DEX lane (recommended when PRIMARY stays on liquidation/collateral).
PRIVATE_KEY_CEX_DEX=
# When this string contains "cex_dex" (substring) and PRIVATE_KEY_CEX_DEX is set, main boots with that key globally.
# Otherwise PRIVATE_KEY signs main-loop lanes; PRIVATE_KEY_CEX_DEX still wires CexDexArbitrage when set.
BOT_SIGNING_STRATEGY=

# Optional: must match pubkey from PRIVATE_KEY or omit (recommended if keys drift).
WALLET_PUBKEY=
# If true, WALLET_PUBKEY mismatch aborts startup (default: warn and continue).
ENFORCE_WALLET_PUBKEY=false

# Single instance: second main.py exits if lock port is taken.
BOT_SINGLETON_LOCK_HOST=127.0.0.1
BOT_SINGLETON_LOCK_PORT=38471
DISABLE_BOT_SINGLETON_LOCK=false
# Phase 0 — next-level Redis singleton (dead-PID reclaim; default on when REDIS_URL set)
BOT_SINGLETON_NEXTLEVEL_GUARD=true
BOT_SINGLETON_NEXTLEVEL_KEY=bot:singleton:nextlevel
BOT_SINGLETON_NEXTLEVEL_TTL_SEC=300
# SIGTERM live holder when duplicate (use with care)
BOT_SINGLETON_TERMINATE_HOLDER=false
BOT_SINGLETON_TERMINATE_WAIT_SEC=3

# Adaptive lane router (fill rate + vol + inventory skew)
ENABLE_ADAPTIVE_ROUTER=true
ADAPTIVE_ROUTER_WINDOW_HOURS=4
ADAPTIVE_ROUTER_FILL_WEIGHT=15
ADAPTIVE_ROUTER_SKEW_WEIGHT=12

# Plan 9 — USDC inventory sync (SOL-heavy → Jupiter sell slice for USDC)
USDC_INVENTORY_TARGET_PCT=30
USDC_INVENTORY_SYNC_INTERVAL_HOURS=6
USDC_INVENTORY_SWAP_FRAC=0.20
USDC_INVENTORY_SOL_THRESHOLD=0.35

# Plan 10 — post-fill auto-tuner (Docker: ENABLE_AUTO_TUNER_ON_START=true)
ENABLE_AUTO_TUNER_ON_START=false

# Reverse lane USDC bootstrap (after first live_fill)
ENABLE_REVERSE_USDC_BOOTSTRAP=true
REVERSE_BOOTSTRAP_MIN_LIVE_FILLS=1
REVERSE_BOOTSTRAP_MIN_USDC=8

# ML regime detector (Phase 4)
ENABLE_ML_REGIME_DETECTOR=false
ML_REGIME_MODEL_PATH=models/regime_detector.joblib

# Execution safety — keep TEST_MODE=true until sizing/sims are trusted.
TEST_MODE=true
LIVE_TRADING_CONFIRM=

# Monitor loop circuit breaker (pybreaker): trip after N tick failures, pause reset_timeout sec.
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# Wallet safety — align MAX_SINGLE_TRADE_USDC_MICRO with collateral/backrun flash sizes.
MIN_SUCCESSFUL_SIMS_BEFORE_LIVE=5
ENFORCE_MIN_SIMS_BEFORE_LIVE=false
# Space out live sends; pairs well with selective AI (e.g. 90–300 seconds).
LIVE_TRADE_COOLDOWN_SECONDS=90
MAX_DAILY_VOLUME_USDC_MICRO=0
MAX_SINGLE_TRADE_USDC_MICRO=0
# Cap completed live trades per UTC hour (0 = unlimited). Count advances on successful sends only.
MAX_LIVE_TRADES_PER_HOUR=8
WALLET_SAFETY_STATE_PATH=logs/wallet_safety_state.json
# wallet_safety.record_cex_reconciliation: logger.critical when |delta_sol| exceeds this.
CEX_RECONCILIATION_CRITICAL_DRIFT_SOL=2.0

# --- Jupiter (quotes / swaps for collateral + backrun) ---
MIN_PROFIT_PERCENT=0.06
MAX_SLIPPAGE_BPS=100
JUPITER_QUOTE_URL=https://lite-api.jup.ag/swap/v1/quote
JUPITER_QUOTE_URLS=["https://api.jup.ag/swap/v1/quote","https://quote-api.jup.ag/v6/quote"]
JUPITER_SWAP_URLS=["https://api.jup.ag/swap/v1/swap","https://quote-api.jup.ag/v6/swap"]
JUPITER_API_KEY=
JUPITER_QUOTE_MIN_INTERVAL_SEC=0.35
JUPITER_QUOTE_MAX_CONCURRENT=2
JUPITER_QUOTE_MAX_RETRIES=5
JUPITER_QUOTE_RETRY_DELAY_SEC=0.6

# CEX price discovery (Backpack primary; skip geo-blocked venues)
CEX_SKIP_VENUES=bybit
CEX_SYMBOL_USDT_FALLBACK=true
CEX_PRICE_MAX_CONCURRENT=3
DENY_DOT_ENV_TXT=true

# --- AI (decisive on winners, sparse trades) ---
# Model must exceed this confidence to approve (raise for fewer trades).
AI_APPROVE_MIN_CONFIDENCE=72
# CEX-DEX lane uses max(AI_APPROVE_MIN_CONFIDENCE, CEX_DEX_AI_CONFIDENCE_FLOOR); lower both to surface more signals.
CEX_DEX_AI_CONFIDENCE_FLOOR=72
LIQUIDATION_AI_MIN_CONFIDENCE=72
# Optional extras after model APPROVE (percent points where applicable).
# Leave blank to disable each gate.
AI_APPROVE_MIN_PROFIT_PCT=
AI_APPROVE_MIN_EST_NET_PCT=0.06
ENABLE_AI_CYCLE_BRAIN=true
ENABLE_DAILY_STRATEGY_AI=true
# ML ensemble weights (heuristic brain + LightGBM + optional regime model)
ML_ENSEMBLE_HEURISTIC_WEIGHT=0.35
ML_ENSEMBLE_LGBM_WEIGHT=0.50
ML_ENSEMBLE_REGIME_WEIGHT=0.15
ML_RETRAIN_ON_APPROVE=false

# Cycle brain: tie-break order (cex_dex first when scoring ties after biases).
# When snapshot cex_dex.active, extra bias CEX_DEX_BRAIN_PRIORITY_BIAS is applied so cex_dex usually wins.
# Set STRATEGY_PRIORITY_SCORE_BIAS=0 to disable collateral/backrun bias (cex_dex active bonus unchanged).
STRATEGY_PRIORITY_ORDER=cex_dex,dex_cex_reverse,backrun,collateral_swap,liquidation
ENABLE_DEX_CEX_REVERSE=true
DEX_CEX_REVERSE_MIN_GROSS_BPS=8
DEX_CEX_REVERSE_SLIPPAGE_BPS=60
DEX_CEX_REVERSE_SIZE_USDC_MICRO=12000000
DEX_CEX_REVERSE_CEX_BUFFER_SEC=8
DEX_CEX_REVERSE_SELL_RESERVE_SOL=0.01
STRATEGY_PRIORITY_SCORE_BIAS=14
CEX_DEX_BRAIN_PRIORITY_BIAS=80
CEX_DEX_ENABLE_MIDCAP_LIVE=true
STRATEGY_WIN_THRESHOLD=28
DAILY_STRATEGY_REVIEW_PATH=logs/daily_strategy_review.txt
OPENAI_API_KEY=

JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6/quote
JUPITER_SWAP_URL=https://lite-api.jup.ag/swap/v1/swap
JUPITER_API_KEY=
# Route quality (SOL/USDC): tighter slippage, direct routes, restrict intermediate tokens.
JUPITER_SOL_USDC_SLIPPAGE_BPS=40
JUPITER_ONLY_DIRECT_ROUTES=true
JUPITER_RESTRICT_INTERMEDIATE_TOKENS=true
JUPITER_DYNAMIC_SLIPPAGE=true
JUPITER_USE_SHARED_ACCOUNTS=true
JUPITER_MAX_ACCOUNTS=64
# Comma-separated extra quote fallbacks (v6 first in code builtins).
JUPITER_QUOTE_FALLBACK_URLS=

SHOW_FULL_PRIVATE_KEY=
KEYPAIR_JSON_PATH=

# Stop loading `.env.txt` after migrating secrets to `.env` only.
DENY_DOT_ENV_TXT=false
STRICT_HTTPS_ENDPOINTS=false

# --- Collateral + mempool (main.py) ---
ENABLE_COLLATERAL_RATE_ARB=true
COLLATERAL_MIN_SPREAD_BPS=150
COLLATERAL_FLASH_AMOUNT_USDC_MICRO=50000000
# Kamino lend market for GET .../kamino-market/{pubkey}/reserves/metrics (default Main Market).
KAMINO_LENDING_MARKET_PUBKEY=7u3HeHxYDLhnCoErrtycNokbQYbWGzLs6JSDqGAv5PfF
ENABLE_MEMPOOL_WATCHER=false
JITO_TIP_ACCOUNT=
JITO_TIP_LAMPORTS=100000
JITO_TIP_LAMPORTS_HIGH=200000
JITO_TIP_VOLATILITY_MODE=true
# === Optimized Jito Tipping (Small Budget) ===
JITO_DYNAMIC_TIP=true
JITO_TIP_PROFIT_RATIO=0.35
JITO_TIP_MIN_LAMPORTS=80000
JITO_TIP_MAX_LAMPORTS=250000
JITO_TIP_FLOOR_MULTIPLIER=1.05
JITO_TIP_FILL_RATE_TARGET=0.6
JITO_TIP_FILL_RATE_MAX_BOOST=0.30
JITO_TIP_FILL_RATE_WINDOW_HOURS=2
V2_STRONG_JITO_TIP_MULT=1.15
JITO_SUBMIT_MULTI_REGION=true
JITO_TIP_USE_LIVE_FLOOR=true
JITO_TIP_SOL_USD=180
JITO_TIP_FALLBACK_NET_USD=8.0
JITO_AWAIT_BUNDLE_POLL=true
JITO_BUNDLE_POLL_TIMEOUT_SEC=45
JITO_BUNDLE_POLL_INTERVAL_SEC=0.5

# Midcap bases polled as {SYMBOL}/USDC (SOL/USDC always included). Max symbols = CEX_MAX_MIDCAPS (default 20).
CEX_MIDCAPS=BONK,WIF,JUP,PYTH,RAY,JTO,ORCA,POPCAT,W,DRIFT,GMT,MEW,SAMO,FIDA,FARTCOIN
CEX_MAX_MIDCAPS=20

# CEX price discovery (Backpack → Bybit → OKX → KuCoin; orders only on Backpack).
CEX_PRICE_FEED_PRIMARY=backpack
CEX_CACHE_TTL_SECONDS=30
CEX_PRICE_FAIL_LOG_INTERVAL_SECONDS=180
CEX_PRICE_BATCH_LOG_INTERVAL_SECONDS=45

# --- CEX-DEX Arb / Backpack ↔ Jupiter (cex_dex_arb.py) ---
# Oracle ~2–5s jitter (CEX_DEX_ORACLE_*): CEX book + Jupiter quote → net spread vs MIN_NET → AI gate → Jito bundle on-chain leg.
# Typical gross edges ~0.5–3%+; detector subtracts modeled CEX/Jupiter/slippage/Kamino/Jito-withdraw drag (see CEX_DEX_*_BPS / MICRO).
CEX_DEX_PRIMARY_VENUE=backpack
CEX_DEX_BACKPACK_MARKET=SOL_USDC
# Public WS (docs: wss://ws.backpack.exchange — not stream.backpack.exchange)
BACKPACK_WS_URL=wss://ws.backpack.exchange
BACKPACK_WS_PING_INTERVAL_SEC=20
BACKPACK_WS_PING_TIMEOUT_SEC=60
# Reference spot symbol for scripts (fetch_cex_dex_prices.py): Bybit SOLUSDC
CEX_DEX_BYBIT_SYMBOL=SOLUSDC
# Pre-filter on gross bps (cheap sanity check before net math).
CEX_DEX_MIN_GROSS_SPREAD_BPS=10
# Minimum *net* spread after modeled costs (bps); uses single base cost unless component model on.
CEX_DEX_MIN_NET_SPREAD_BPS=4
# Soft rescue: allow selected symbols to pass when roundtrip sim confirms net.
CEX_DEX_MODEL_NET_SOFT_RESCUE=true
CEX_DEX_MODEL_NET_SOFT_RESCUE_MIN_GROSS_BPS=8
CEX_DEX_MODEL_NET_SOFT_RESCUE_SYMBOLS=SOL,WIF,BONK,POPCAT,MEW,PNUT,FARTCOIN
CEX_DEX_FOCUS_SCAN_SYMBOLS=SOL,BONK,WIF,POPCAT,MEW,PNUT,FARTCOIN
CEX_DEX_OPPORTUNITY_LOG_TOP_N=3
CEX_DEX_EXEC_CANDIDATE_QUEUE_N=3
CEX_DEX_EXEC_CANDIDATE_EXEC_N=3
CEX_DEX_MODEL_NET_SOFT_RESCUE_BYPASS_NET_GATE=true
CEX_DEX_MODEL_NET_SOFT_RESCUE_MIN_SIM_NET_BPS=0.5
CEX_DEX_MODEL_NET_SOFT_RESCUE_SIM_TIMEOUT_SEC=3.5
CEX_DEX_MODEL_NET_SOFT_RESCUE_SIM_TIMEOUT_RETRIES=1
CEX_DEX_MODEL_NET_SOFT_RESCUE_SIM_TIMEOUT_MAX_RETRIES=4
CEX_DEX_MODEL_NET_SOFT_RESCUE_TIMEOUT_EDGE_BPS=35
CEX_DEX_MODEL_NET_SOFT_RESCUE_SIZE_LADDER=1.0,0.7,0.5,0.35,0.25,0.18,0.12
CEX_DEX_MODEL_NET_SOFT_RESCUE_MIN_TRADE_USDC_MICRO=4500000
CEX_DEX_MODEL_NET_SOFT_RESCUE_PAIR_POLICY_PATH=logs/rescue_pair_policy.json
CEX_DEX_MODEL_NET_SOFT_RESCUE_POLICY_CACHE_SEC=60
CEX_DEX_MODEL_NET_SOFT_RESCUE_RECALIBRATE_CONFIDENCE=true
CEX_DEX_MODEL_NET_SOFT_RESCUE_CALIBRATION_PATH=logs/rescue_confidence_calibration.json
CEX_DEX_MODEL_NET_SOFT_RESCUE_CALIBRATION_CACHE_SEC=120
CEX_DEX_MODEL_NET_SOFT_RESCUE_USE_DEPTH_HINTS=true
CEX_DEX_MODEL_NET_SOFT_RESCUE_DEPTH_LEVELS=12
CEX_DEX_MODEL_NET_SOFT_RESCUE_DEPTH_FRACTIONS=0.25,0.4,0.6,0.8,1.0
# Experimental near-breakeven mode (off by default): allow small negative pre-sim only with strict edge/conf/size checks.
CEX_DEX_MODEL_NET_SOFT_RESCUE_ALLOW_NEGATIVE_SIM=false
CEX_DEX_MODEL_NET_SOFT_RESCUE_NEGATIVE_SIM_MAX_LOSS_BPS=5
CEX_DEX_MODEL_NET_SOFT_RESCUE_NEGATIVE_SIM_MIN_EDGE_BPS=35
CEX_DEX_MODEL_NET_SOFT_RESCUE_NEGATIVE_SIM_MIN_AI_CONF=78
CEX_DEX_MODEL_NET_SOFT_RESCUE_NEGATIVE_SIM_MAX_SIZE_USDC=12
CEX_DEX_MODEL_NET_SOFT_RESCUE_NEGATIVE_SIM_DAILY_BUDGET=6
CEX_DEX_MODEL_NET_SOFT_RESCUE_NEGATIVE_SIM_MAX_CONSEC_LOSSES=2
CEX_DEX_MODEL_NET_SOFT_RESCUE_NEGATIVE_SIM_STATE_PATH=logs/rescue_negative_tier_state.json
# Per-pair adaptive rescue profile from recent conversion quality.
CEX_DEX_ADAPTIVE_RESCUE_LOW_SCORE_MIN_NET_DELTA=0.35
CEX_DEX_ADAPTIVE_RESCUE_LOW_SCORE_SIZE_MULT=0.75
CEX_DEX_ADAPTIVE_RESCUE_HIGH_SCORE_MIN_NET_DELTA=-0.2
CEX_DEX_ADAPTIVE_RESCUE_HIGH_SCORE_SIZE_MULT=1.05
CEX_DEX_ADAPTIVE_RESCUE_HIGH_DRIFT_BPS=16
CEX_DEX_ADAPTIVE_RESCUE_HIGH_DRIFT_MIN_NET_DELTA=0.25
CEX_DEX_ADAPTIVE_RESCUE_HIGH_DRIFT_SIZE_MULT=0.85
# Per-pair lifecycle states (observe/micro/full, optional paper disable).
CEX_DEX_LIFECYCLE_WARMUP_ATTEMPTS=4
CEX_DEX_LIFECYCLE_PAPER_SCORE=0.2
CEX_DEX_LIFECYCLE_MICRO_SCORE=0.45
CEX_DEX_LIFECYCLE_PAPER_ALLOW_LIVE=false
CEX_DEX_LIFECYCLE_OBSERVE_MAX_USDC=8
CEX_DEX_LIFECYCLE_MICRO_MAX_USDC=14
CEX_DEX_LIFECYCLE_PAPER_MAX_USDC=5
CEX_DEX_LIFECYCLE_OBSERVE_EXTRA_NET_BPS=0.5
CEX_DEX_LIFECYCLE_MICRO_EXTRA_NET_BPS=0.25
CEX_DEX_LIFECYCLE_PAPER_EXTRA_NET_BPS=1.0
# Execute-time coherence guard for rescue->execution drift.
CEX_DEX_EXEC_ROUNDTRIP_DRIFT_SOFT_BAND_BPS=0.35
CEX_DEX_EXEC_ROUNDTRIP_DRIFT_MAX_BPS=12
# Per-pair temporary cooldown after repeated execute-time roundtrip failures.
CEX_DEX_EXEC_ROUNDTRIP_FAIL_STREAK=3
CEX_DEX_EXEC_ROUNDTRIP_FAIL_COOLDOWN_SEC=900
CEX_DEX_EXEC_ROUNDTRIP_COOLDOWN_ENABLED=true
# CEX price micro-stability check before live execute.
CEX_DEX_EXEC_CEX_STABILITY_ENABLED=true
CEX_DEX_EXEC_CEX_STABILITY_SNAPSHOTS=3
CEX_DEX_EXEC_CEX_STABILITY_GAP_MS=150
CEX_DEX_EXEC_CEX_STABILITY_MAX_DRIFT_BPS=4
# Detect->execute route fingerprint drift guard.
CEX_DEX_EXEC_ROUTE_DRIFT_GUARD_ENABLED=true
CEX_DEX_EXEC_ROUTE_HOPS_MAX_DELTA=2
CEX_DEX_EXEC_ROUTE_IMPACT_MAX_DELTA_BPS=120
# Optional pilot-first sizing (1.0 disables staging; e.g. 0.5 runs half-size first).
CEX_DEX_EXEC_STAGE1_FRACTION=1.0
# Pair quality routing bonus (bps) from observed conversion quality.
CEX_DEX_PAIR_SCORE_WEIGHT_BPS=6
CEX_DEX_PAIR_SCORE_MIN_SAMPLES=5
CEX_DEX_PAIR_SCORE_DRIFT_CAP_BPS=40
CEX_DEX_PAIR_QUALITY_DRIFT_ALPHA=0.25
# Dynamic per-pair execution size multiplier from fill quality score.
CEX_DEX_PAIR_SIZE_MIN_MULT=0.6
CEX_DEX_PAIR_SIZE_MAX_MULT=1.2
# Runtime auto-tighten/relax guardrails from recent execute-quality window.
CEX_DEX_RUNTIME_GUARD_ENABLED=true
CEX_DEX_RUNTIME_GUARD_WINDOW_SEC=1800
CEX_DEX_RUNTIME_GUARD_HIGH_BLOCK_RATE=0.45
CEX_DEX_RUNTIME_GUARD_HIGH_DRIFT_BPS=14
CEX_DEX_RUNTIME_GUARD_TIGHTEN_FACTOR=0.75
CEX_DEX_RUNTIME_GUARD_STAGE1_FRACTION=0.6
# Per-pair route-family memory (hops) to bias toward stable routes.
CEX_DEX_ROUTE_PREF_ALPHA=0.2
CEX_DEX_ROUTE_PREF_MIN_SAMPLES=5
CEX_DEX_ROUTE_PREF_PENALTY_BPS_PER_HOP=1.5
CEX_DEX_LOG_NEAR_MISSES=true
CEX_DEX_NEAR_MISS_LOG_PATH=logs/cex_dex_near_misses.jsonl
CEX_DEX_AGGRESSIVE_ROUNDTRIP_SIM=true
CEX_DEX_ROUNDTRIP_SIM_MIN_NET_BPS=3
CEX_DEX_ROUNDTRIP_SIM_MIN_RETAIN_FRAC=0.55
CEX_DEX_ROUNDTRIP_USE_TRADE_SIZE=true
# v2 roundtrip sim: safety buffer + dynamic slippage (gates.py)
V2_ROUNDTRIP_NET_SAFETY_MULT=1.2
V2_ROUNDTRIP_PROBE_USDC_MICRO=25000000
V2_ROUNDTRIP_SLIPPAGE_BASE_BPS=60
V2_ROUNDTRIP_SLIPPAGE_SIZE_SCALE=1.5
V2_ROUNDTRIP_RETAIN_CHECK=true
V2_ROUNDTRIP_SOFT_PASS_FACTOR=0.85
CEX_DEX_ROUNDTRIP_AT_DETECT=true
CEX_DEX_SOL_SELL_RESERVE_SOL=0.02
CEX_DEX_INVENTORY_FIRST=true
CEX_DEX_INVENTORY_BUFFER_FRAC=1.05
CEX_DEX_AGGRESSIVE_OPPORTUNITY_FILTER=false
ENABLE_ONCHAIN_PROFIT_ASSERT=true
ONCHAIN_PROFIT_ASSERT_BPS=12
ONCHAIN_PROFIT_ASSERT_STRICT=true
ML_REAL_FILLS_APPROVE_GATE=true
ML_REAL_FILLS_APPROVE_MIN_PROBA=0.68
CEX_DEX_JUPITER_ROUNDTRIP_CHECK=false
CEX_DEX_EXEC_SWAP_MAX_ATTEMPTS=3
CEX_MIN_BOOK_DEPTH_MULT=1.5
CEX_MAX_BOOK_SPREAD_BPS=30
CEX_BALANCE_CACHE_TTL_SEC=2.0
# Modeled drag (bps except withdrawal micro): round-trip CEX taker-style + Jupiter buffer + exec slippage buffer + Kamino flash.
CEX_DEX_CEX_FEE_ROUNDTRIP_BPS=20
CEX_DEX_JUPITER_LEG_FEE_BUFFER_BPS=15
CEX_DEX_EXECUTION_SLIPPAGE_BUFFER_BPS=100
CEX_DEX_KAMINO_FLASH_FEE_BPS=5
# Fixed USDC cost (6 decimals) folded into bps at MAX_TRADE size (bridge/withdraw friction).
CEX_DEX_WITHDRAWAL_BRIDGE_USDC_MICRO=0
# Tip lamports for drag model midpoint (override single tip); bundle send uses CEX_DEX_JITO_TIP_LAMPORTS or default.
# CEX_DEX_JITO_TIP_LAMPORTS_OVERRIDE=
CEX_DEX_JITO_TIP_LAMPORTS=100000
# (Oracle poll min/max also set above with vol gate — keep in sync)
CEX_DEX_ORACLE_JITTER=true
# Fixed poll when jitter=false (still clamped to min/max).
# CEX_DEX_POLL_INTERVAL_SECONDS=3
# Hard cap per opportunity signal (USDC micro). E.g. 150000000 = 150 USDC.
CEX_DEX_MAX_TRADE_USDC_MICRO=150000000
# Sleep between CEX buy and on-chain leg (cex_cheap path); also minimum sleep in strategy.
CEX_WITHDRAWAL_BUFFER_SEC=25
# Flash size clamp used by cex_dex_flash_arb / Kamino USDC borrow sizing (USDC micro).
CEX_DEX_FLASH_AMOUNT_USDC_MICRO=35000000
# Verbose INFO logs in cex_dex_flash_arb (slippage / Kamino fee / sim CU). Set false to quiet.
CEX_DEX_FLASH_SIM_DEBUG=true
CEX_DEX_FLASH_QUOTE_SLIPPAGE_BPS=80
CEX_DEX_FLASH_JITO_TIP_LAMPORTS=85000
# --- CexDexStrategy (cex_dex_core + cex_dex_strategy.py) ---
# Base modeled drag (bps): Jupiter/slippage/Kamino/Jito lump sum. Alias: CEX_DEX_STRATEGY_MODEL_COST_BPS.
CEX_DEX_STRATEGY_BASE_COST_BPS=11
CEX_DEX_USE_COMPONENT_COST_MODEL=false
CEX_DEX_MAX_SIZE_IMPACT_BPS=5
CEX_DEX_SIZE_IMPACT_SLOPE_BPS=6
CEX_DEX_PROBE_USDC_MICRO=12000000
# CEX buy reference = best ask (not mid) for spread / direction alignment.
CEX_USE_ASK_FOR_BUY=true
# Vol gate: skip cycle when 5m range < 0.8% and gross < 15 bps.
CEX_DEX_VOL_GATE_ENABLED=true
CEX_DEX_ADAPTIVE_GATES_ENABLED=true
CEX_DEX_VOL_5M_LOW_THRESHOLD_PCT=0.8
CEX_DEX_VOL_SKIP_MAX_GROSS_BPS=15
# Adaptive tiers (VolatilityGate stdev %): aggressive >1.2 | opportunistic >0.7 | else strict
CEX_VOL_AGGRESSIVE_PCT=1.2
CEX_VOL_OPPORTUNISTIC_PCT=0.7
CEX_VOL_CACHE_SEC=30
CEX_VOL_DEFAULT_LOW=0.4
# Faster oracle polling when 5m vol is elevated (main loop).
CEX_DEX_ORACLE_POLL_MIN_SEC=1
CEX_DEX_ORACLE_POLL_MAX_SEC=5
CEX_DEX_HIGH_ACTIVITY_VOL_PCT=0.8
# Auto looser gates when 5m CEX range > CEX_DEX_OPPORTUNISTIC_VOL_PCT
CEX_DEX_VOL_OPPORTUNISTIC_AUTO=true
CEX_DEX_OPPORTUNISTIC_VOL_PCT=0.8
CEX_DEX_OPP_MIN_GROSS_BPS=6
CEX_DEX_OPP_MIN_NET_BPS=0
CEX_DEX_OPP_AI_CONF=62
CEX_DEX_OPP_ROUNDTRIP_MIN_NET_BPS=0
# Auto gate switcher (scripts/auto_gate_switcher.py): strict when vol low, opportunistic when > threshold
AUTO_GATE_POLL_SEC=300
# AUTO_GATE_STATE_PATH=logs/auto_gate_mode.txt
# After first SOL fill: enable one midcap at a time.
# CEX_MIDCAPS=SOL,WIF
CEX_DEX_MAX_TRADE_USDC_MICRO=12000000
JITO_TIP_LAMPORTS=100000
# Extra bps charged against *gross* edge for hybrid cex_cheap (withdrawal / latency risk).
CEX_DEX_WITHDRAWAL_LATENCY_BPS=20
# Optional: add ``CEX_WITHDRAWAL_BUFFER_SEC * rate`` bps to latency drag (0 disables).
CEX_DEX_WITHDRAWAL_LATENCY_BPS_PER_SEC=0
# CEX-DEX AI approve floor; effective threshold is max(this, AI_APPROVE_MIN_CONFIDENCE).
CEX_DEX_AI_CONFIDENCE_FLOOR=72
# Fraction [0–1] of visible CEX SOL depth (top levels) converted to USDC notional cap.
CEX_DEX_DEPTH_UTILIZATION=0.55
# Shrink size when Jupiter ExactIn quote impact exceeds this (%); one rescale pass.
CEX_DEX_MAX_ROUTE_PRICE_IMPACT_PCT=0.55
# Skip trades below this notional (USDC micro).
CEX_DEX_MIN_TRADE_USDC_MICRO=5000000
# Logical cap on CEX-attributed SOL inventory before sizing buys down.
CEX_DEX_MAX_INVENTORY_SOL=75
# If true, fetch SOL free balance once at startup to seed inventory estimator.
CEX_DEX_SYNC_INVENTORY_ON_START=false
# Set true to run only dex_cheap (atomic on-chain leg); block hybrid cex_cheap.
CEX_DEX_DISABLE_HYBRID_CEX_CHEAP=false
# Volatility (bps) × size for withdrawal-window risk logging (cex_cheap).
CEX_DEX_WITHDRAWAL_VOLATILITY_BPS=80
# Optional extra clamp below MAX for staging (USDC micro).
# CEX_DEX_SOFT_CAP_USDC_MICRO=
# Jupiter probe size for implied USDC/SOL (USDC micro).
# CEX_DEX_JUPITER_PROBE_USDC_MICRO=1000000000

# Backpack — keys required for trading / withdrawals / balances.
BACKPACK_API_KEY=your_ed25519_pubkey
BACKPACK_SECRET=your_ed25519_private_key_base58

# --- Helius webhooks + optional backrun (strategy mix; needs HTTPS tunnel) ---
# Backrun requires ENABLE_HELIUS_WEBHOOK=true and a reachable HELIUS_WEBHOOK_PUBLIC_URL (tunnel).
ENABLE_HELIUS_WEBHOOK=true
ENABLE_HELIUS_FASTAPI=false
FASTAPI_WEBHOOK_HOST=0.0.0.0
FASTAPI_WEBHOOK_PORT=8000
FASTAPI_HELIUS_WEBHOOK_PATH=/webhook
FASTAPI_HELIUS_HEALTH_PATH=/health
FASTAPI_WEBHOOK_BIND_DISPLAY_HOST=127.0.0.1
UVICORN_LOG_LEVEL=info
# Logging: json = Loki-friendly lines; USE_STRUCTLOG adds structlog processors (default on).
LOG_FORMAT=json
USE_STRUCTLOG=true
LOG_SERVICE_NAME=solana-arb-monitor
LOG_DIR=logs

HELIUS_WEBHOOK_HOST=0.0.0.0
HELIUS_WEBHOOK_PORT=8799
HELIUS_WEBHOOK_PATH=/helius/webhook
HELIUS_WEBHOOK_HEALTH_PATH=/helius/health
HELIUS_WEBHOOK_SECRET=
HELIUS_WEBHOOK_REQUIRE_SIGNATURE=true
HELIUS_WEBHOOK_AUTH_TOKEN=
HELIUS_JUPITER_SOURCES=JUPITER

HELIUS_API_KEY=
HELIUS_WEBHOOK_PUBLIC_URL=https://your-tunnel.example.com
ENABLE_HELIUS_WEBHOOK_BACKRUN=true
HELIUS_WEBHOOK_AUTO_CREATE=false
HELIUS_WEBHOOK_MONITOR_ACCOUNTS=JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4
HELIUS_WEBHOOK_TXN_STATUS=confirmed
HELIUS_BACKRUN_MIN_AMOUNT_MICRO=50000000
HELIUS_BACKRUN_AMOUNT_FRACTION=0.8

# === LOCAL PRODUCTION UPGRADES ===
SOLANA_RPC_URL_FAST=https://your-helius-or-quicknode-endpoint
YELLOWSTONE_GRPC_URL=grpc://your-geyser.yellowstone.example:10000
ENABLE_GEYSER=true
GEYSER_POOL_KEYS=
GEYSER_TOKEN=
GEYSER_GRPC_TOKEN=
JITO_BLOCK_ENGINE_URLS=ny.mainnet.block-engine.jito.wtf,frankfurt.mainnet.block-engine.jito.wtf,amsterdam.mainnet.block-engine.jito.wtf,tokyo.mainnet.block-engine.jito.wtf

MIN_NET_PROFIT_BPS=45
DYNAMIC_TIP_MULTIPLIER=0.6
MAX_TIP_LAMPORTS=3000000
AI_APPROVE_MIN_CONFIDENCE=78
CEX_DEX_MAX_TRADE_USDC_MICRO=75000000
CEX_DEX_MIN_TRADE_USDC_MICRO=10000000

# Risk
MAX_DRAWDOWN_PCT=3.0
INVENTORY_MAX_SOL=45
ENABLE_ONCHAIN_PROFIT_ASSERT=true
ENABLE_ONCHAIN_PROFIT_CHECK=true
ONCHAIN_PROFIT_ASSERT_BPS=20
# Post-trade USDC balance delta must clear threshold (trips breaker on fail)

# Telegram alerts (win rate, circuit breaker, drawdown)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WIN_RATE_ALERT=true
TELEGRAM_CIRCUIT_BREAKER_ALERT=true
WIN_RATE_ALERT_WINDOW_TRADES=50
WIN_RATE_ALERT_MIN_PCT=60

# Global safety + inventory (drawdown 3%, reconcile, circuit breaker)
ENABLE_GLOBAL_SAFETY_MONITOR=true
GLOBAL_SAFETY_INTERVAL_SEC=60

# Multi-DEX Jupiter routes (Phoenix / Raydium / Orca alongside aggregators)
ENABLE_MULTI_DEX_ROUTES=false
MULTI_DEX_PREFERRED=Phoenix,Raydium,Orca

# Brain: when CEX-DEX gross < threshold, boost liquidation/collateral lanes
BRAIN_CEX_DEX_WEAK_REDIRECT=true
BRAIN_CEX_DEX_WEAK_GROSS_BPS=60
ENABLE_PHOENIX_V1=true
PHOENIX_SOL_USDC_MARKET=4DoNfFBfF7UokCC2FQzriy7yHK6DY6NVdYpuekQ5pRgg
PHOENIX_PROBE_USDC_MICRO=12000000

# Multi-strat priority
STRATEGY_PRIORITY_ORDER=cex_dex,liquidation,collateral_swap,backrun
STRATEGY_PRIORITY_SCORE_BIAS=18

WALLET_EQUITY_BASELINE_USD=0
GLOBAL_SAFETY_CHECK_INTERVAL_SEC=60
CIRCUIT_BREAKER_LOSS_STREAK=3
CIRCUIT_BREAKER_LOSS_COOLDOWN_SEC=300
CIRCUIT_BREAKER_LOSS_USD=10
INVENTORY_RECONCILE_STRICT_MODE=true
INVENTORY_RECONCILE_STRICT_DELTA_SOL=0.15
INVENTORY_RECONCILE_STRICT_CROSS_DELTA_SOL=0.35
CEX_RECONCILIATION_CRITICAL_DRIFT_SOL=2.0
CEX_RECONCILIATION_TRIP_BREAKER=true

# --- Production secrets (docker-compose.prod.yml) ---
# Mount files under ./secrets/; compose sets *_FILE paths under /run/secrets/.
# Run: bash scripts/setup-secrets.sh
APP_ENV=development
SIGNER_TYPE=hot
GNOSIS_SAFE_ADDRESS=
TIMELOCK_ADDRESS=
# SECRET_MANAGER: local (default) | vault | aws
SECRET_MANAGER=local
VAULT_ADDR=
PRIVATE_KEY_FILE=
PRIVATE_KEY_CEX_DEX_FILE=
JUPITER_API_KEY_FILE=
OPENAI_API_KEY_FILE=
BACKPACK_SECRET_FILE=
HELIUS_API_KEY_FILE=

# --- Docker Compose: Redis + health/metrics (port 8000) ---
REDIS_URL=redis://redis:6379/0
REDIS_CYCLE_TTL_SEC=120
ENABLE_BOT_HEALTH_SERVER=true
BOT_HEALTH_HOST=0.0.0.0
BOT_HEALTH_PORT=8000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Logging (Loki host port — use 3101 if 3100 is taken by another stack e.g. flash-loki)
LOKI_PORT=3101
LOKI_HOST=0.0.0.0
